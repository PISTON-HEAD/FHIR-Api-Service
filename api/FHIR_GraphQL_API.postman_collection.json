    {
      "name": "4. GraphQL Queries",
      "item": [
        {
          "name": "4.1 Query Patient by Identifier (MRN)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetPatientByIdentifier($identifier: String!) { patient(identifier: $identifier) { id firstName lastName gender dateOfBirth identifiers { type value system } fhirResource } }\",\n  \"variables\": {\n    \"identifier\": \"MRN0001\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:9090/graphql/fhirapi/patient",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["graphql", "fhirapi", "patient"]
            },
            "description": "Query a patient by their MRN identifier"
          },
          "response": []
