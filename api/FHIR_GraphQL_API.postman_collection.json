{
  "info": {
    "name": "FHIR GraphQL Patient API - Complete Testing Suite",
    "description": "Complete collection for testing the FHIR GraphQL Patient Data Service - Includes authentication, patient creation, REST GET search endpoints with multi-parameter support, GraphQL queries, and sample data testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Create User (Signup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "    pm.environment.set(\"username\", jsonData.username);",
                  "    console.log(\"JWT Token saved: \" + jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testdoctor\",\n  \"password\": \"password123\",\n  \"email\": \"testdoctor@hospital.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:9090/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["auth", "signup"]
            },
            "description": "Create a new user account. The JWT token will be automatically saved to environment variables."
          },
          "response": []
        },
        {
          "name": "1.2 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "    pm.environment.set(\"username\", jsonData.username);",
                  "    console.log(\"JWT Token saved: \" + jsonData.token);",
                  "    console.log(\"Token expires in 30 minutes\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "http://localhost:9090/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["auth", "login"]
            },
            "description": "Login with existing credentials. Default: admin/password. JWT token auto-saved."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints for user signup and login"
    },
